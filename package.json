{
  "name": "@vibecontrols/vibe-plugin-ai",
  "version": "2026.428.3",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --external elysia && tsc --emitDeclarationOnly --declaration --declarationMap --outDir ./dist",
    "lint": "eslint ./src",
    "lint:sanity": "if [ \"${CI:-}\" = \"true\" ]; then bun run lint; else bun run lint -- --cache --cache-location .eslintcache; fi",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "sanity": "bun run format:check && bun run lint:sanity && bun run type:check && bun run build && bun run test"
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "ai",
    "claude-code",
    "opencode",
    "codex",
    "copilot",
    "cursor-agent",
    "bun"
  ],
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "description": "AI tool management and prompt templates plugin for VibeControls Agent — manage AI tools, prompt templates with variables (Bun runtime)",
  "dependencies": {
    "elysia": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.16",
    "bun-types": "^1.3.9",
    "commander": "^14.0.3",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@vibecontrols/agent": "2026.428.5"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-ai.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-ai/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://verdaccio.tooling.internal.burdenoff.com/"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "overrides": {
    "lodash": ">=4.17.21",
    "lodash-es": ">=4.17.21",
    "dompurify": ">=3.3.4",
    "fast-xml-parser": ">=4.5.5",
    "@xmldom/xmldom": ">=0.8.12",
    "swiper": ">=12.1.2",
    "brace-expansion": ">=1.1.13",
    "follow-redirects": ">=1.15.12",
    "smol-toml": ">=1.6.1",
    "axios": ">=1.15.0",
    "flatted": ">=3.4.1",
    "yaml": ">=2.8.3",
    "picomatch": ">=2.3.2",
    "immutable": ">=3.8.3",
    "minimatch": ">=3.1.3"
  }
}
